rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'artyushcharchyan0@gmail.com',
          'atucharchyan23@gmail.com'
        ];
    }

    function isAllowedOrderStatus(status) {
      return status in [
        'pending',
        'accepted',
        'preparing',
        'ready',
        'delivered',
        'cancelled'
      ];
    }

    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'id',
          'userId',
          'customerName',
          'phone',
          'address',
          'items',
          'totalPrice',
          'status',
          'createdAt',
        ])
        && request.resource.data.id == orderId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.totalPrice is number
        && request.resource.data.items is list
        && (!('paymentMethod' in request.resource.data)
          || request.resource.data.paymentMethod in ['cash_on_delivery', 'card_online']);

      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        && (!('status' in request.resource.data) || isAllowedOrderStatus(request.resource.data.status));
    }

    match /adminPanel/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow create, update, delete: if request.auth != null
        && request.auth.uid == userId;
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'id',
          'userId',
          'role',
          'type',
          'title',
          'message',
          'read',
          'createdAt',
        ])
        && request.resource.data.id == notificationId
        && request.resource.data.read == false
        && request.resource.data.role in ['admin', 'user']
        && (
          (
            request.resource.data.role == 'admin'
            && request.resource.data.userId == 'admin'
            && request.resource.data.type == 'order_created'
          )
          || (
            isAdmin()
            && request.resource.data.role == 'user'
          )
        );

      allow read: if isAdmin()
        || (
          request.auth != null
          && resource.data.role == 'user'
          && resource.data.userId == request.auth.uid
        );

      allow update: if (
          isAdmin()
          || (
            request.auth != null
            && resource.data.role == 'user'
            && resource.data.userId == request.auth.uid
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
