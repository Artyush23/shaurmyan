rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'artyushcharchyan0@gmail.com',
          'atucharchyan23@gmail.com'
        ];
    }

    function isAllowedOrderStatus(status) {
      return status in [
        'pending',
        'accepted',
        'preparing',
        'ready',
        'delivered',
        'cancelled'
      ];
    }

    function isValidReviewData(data) {
      return data.keys().hasAll([
          'id',
          'productId',
          'userId',
          'userName',
          'author',
          'rating',
          'comment',
          'createdAt',
          'approved',
        ])
        && data.keys().hasOnly([
          'id',
          'productId',
          'userId',
          'userName',
          'author',
          'rating',
          'comment',
          'createdAt',
          'updatedAt',
          'approved',
        ])
        && data.productId is string
        && data.userId is string
        && data.userName is string
        && data.author is string
        && data.comment is string
        && data.comment.size() > 0
        && data.comment.size() <= 600
        && data.rating is int
        && data.rating >= 1
        && data.rating <= 5
        && data.approved is bool;
    }

    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'id',
          'userId',
          'customerName',
          'phone',
          'address',
          'items',
          'totalPrice',
          'status',
          'createdAt',
        ])
        && request.resource.data.id == orderId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.totalPrice is number
        && request.resource.data.items is list
        && (!('paymentMethod' in request.resource.data)
          || request.resource.data.paymentMethod in ['cash_on_delivery', 'card_online']);

      allow read: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin()
        && (!('status' in request.resource.data) || isAllowedOrderStatus(request.resource.data.status));
    }

    match /adminPanel/{docId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow create, update, delete: if request.auth != null
        && request.auth.uid == userId;
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if request.auth != null
        && isValidReviewData(request.resource.data)
        && request.resource.data.id == reviewId
        && request.resource.data.userId == request.auth.uid
        && reviewId == request.resource.data.productId + '_' + request.auth.uid;

      allow update: if (
          isAdmin()
          || (
            request.auth != null
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.productId == resource.data.productId
          )
        )
        && isValidReviewData(request.resource.data)
        && request.resource.data.id == reviewId;

      allow delete: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    match /favorites/{favoriteId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'id',
          'userId',
          'productId',
          'createdAt',
        ])
        && request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'productId',
          'createdAt',
        ])
        && request.resource.data.id == favoriteId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.productId is string
        && favoriteId == request.auth.uid + '_' + request.resource.data.productId;

      allow read, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    match /notifications/{notificationId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'id',
          'userId',
          'role',
          'type',
          'title',
          'message',
          'read',
          'createdAt',
        ])
        && request.resource.data.id == notificationId
        && request.resource.data.read == false
        && request.resource.data.role in ['admin', 'user']
        && (
          (
            request.resource.data.role == 'admin'
            && request.resource.data.userId == 'admin'
            && request.resource.data.type == 'order_created'
          )
          || (
            isAdmin()
            && request.resource.data.role == 'user'
          )
        );

      allow read: if isAdmin()
        || (
          request.auth != null
          && resource.data.role == 'user'
          && resource.data.userId == request.auth.uid
        );

      allow update: if (
          isAdmin()
          || (
            request.auth != null
            && resource.data.role == 'user'
            && resource.data.userId == request.auth.uid
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
