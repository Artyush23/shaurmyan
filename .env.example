# Firebase client configuration
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"

# Optional local Twilio OTP service
API_PORT="3001"
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+10000000000"

# Firebase Functions runtime
FUNCTION_REGION="your_function_region"
ALLOWED_ORIGINS="https://your-frontend.example.com"
BANKING_CALLBACK_URL="https://your-functions-domain.example.com/api/banking/callback"
BANKING_STATE_SECRET="replace_with_a_long_random_secret"

# TBC Open Banking
TBC_OAUTH_CLIENT_ID="your_tbc_client_id"
TBC_CLIENT_SECRET="your_tbc_client_secret"
TBC_OAUTH_AUTHORIZE_URL="https://provider.example.com/oauth/authorize"
TBC_OAUTH_TOKEN_URL="https://provider.example.com/oauth/token"
TBC_OAUTH_SCOPE="your_tbc_oauth_scope"
TBC_ACCOUNTS_URL="https://provider.example.com/api/accounts"
TBC_TRANSACTIONS_URL="https://provider.example.com/api/transactions"

# Bank of Georgia Open Banking
BOG_OAUTH_CLIENT_ID="your_bog_client_id"
BOG_CLIENT_SECRET="your_bog_client_secret"
BOG_OAUTH_AUTHORIZE_URL="https://provider.example.com/oauth/authorize"
BOG_OAUTH_TOKEN_URL="https://provider.example.com/oauth/token"
BOG_OAUTH_SCOPE="your_bog_oauth_scope"
BOG_ACCOUNTS_URL="https://provider.example.com/api/accounts"
BOG_TRANSACTIONS_URL="https://provider.example.com/api/transactions"
